---
layout: null
---
[
{% assign first_search_item = true %}
{% assign menu_markdown_exts = '|md|markdown|' %}

{% for post in site.posts %}
  {% unless first_search_item %},{% endunless %}
  {
    "title"    : "{% if post.title != "" %}{{ post.title | strip_html | escape }}{% else %}{{ post.excerpt | strip_html | escape | strip }}{% endif %}",
    "desc"     : "{% if post.title != "" %}{{ post.title | strip_html | escape }}{% else %}{{ post.excerpt | strip_html | escape | strip }}{% endif %}",
    "category" : "{{ post.tags | join: ', ' }}",
    "url"      : "{{ site.baseurl }}{{ post.url | escape }}",
    "date"     : "{{ post.date | date: "%B %e, %Y" | default: "January 1, 1970" }}"
  }
  {% assign first_search_item = false %}
{% endfor %}

{% for page in site.html_pages %}
  {% if page.title != "{title}" and page.title != "404 - Page not found" and page.search_exclude != true %}
    {% unless first_search_item %},{% endunless %}
    {
      "title"    : "{% if page.title != "" %}{{ page.title | strip_html | escape }}{% else %}{{ page.excerpt | strip_html | escape | strip }}{% endif %}",
      "desc"     : "{% if page.title != "" %}{{ page.title | strip_html | escape }}{% else %}{{ page.excerpt | strip_html | escape | strip }}{% endif %}",
      "category" : "{% if page.tags %}{{ page.tags | join: ', ' }}{% else %}page{% endif %}",
      "url"      : "{{ site.baseurl }}{{ page.url }}",
      "date"     : "{{ page.date | date: '%B %e, %Y' | default: "January 1, 1970" }}"
    }
    {% assign first_search_item = false %}
  {% endif %}
{% endfor %}

{% for link in site.navbar-links %}
  {% assign top_text = link[0] %}
  {% assign top_item = link[1] %}
  {% if top_item.first %}
    {% for childlink in top_item %}
      {% for linkparts in childlink %}
        {% assign child_text = linkparts[0] %}
        {% assign child_item = linkparts[1] %}
        {% if child_item.first %}
          {% for subchild in child_item %}
            {% for subparts in subchild %}
              {% assign sub_text = subparts[0] %}
              {% assign sub_item = subparts[1] %}
              {% if sub_item.first %}
                {% for grandchild in sub_item %}
                  {% for grandparts in grandchild %}
                    {% assign grand_text = grandparts[0] %}
                    {% assign normalized_grand_item = grandparts[1] | strip %}
                    {% assign grand_item_path = normalized_grand_item | split: '#' | first | split: '?' | first | downcase %}
                    {% assign grand_ext = grand_item_path | split: '.' | last %}
                    {% assign grand_ext_marker = '|' | append: grand_ext | append: '|' %}
                    {% unless normalized_grand_item contains 'javascript:' or normalized_grand_item contains 'mailto:' or normalized_grand_item contains 'tel:' %}
                      {% if normalized_grand_item contains '://' %}
                        {% unless first_search_item %},{% endunless %}
                        {
                          "title"    : "{{ grand_text | strip_html | escape }}",
                          "desc"     : "קישור חיצוני מתפריט {{ top_text | strip_html | escape }} / {{ child_text | strip_html | escape }} / {{ sub_text | strip_html | escape }}: {{ grand_text | strip_html | escape }}",
                          "category" : "{{ top_text | strip_html | escape }}, {{ child_text | strip_html | escape }}, {{ sub_text | strip_html | escape }}, קישור חיצוני",
                          "url"      : "{{ normalized_grand_item | escape }}",
                          "date"     : "January 1, 1970"
                        }
                        {% assign first_search_item = false %}
                      {% elsif grand_item_path contains '.' %}
                        {% unless menu_markdown_exts contains grand_ext_marker %}
                          {% unless first_search_item %},{% endunless %}
                          {
                            "title"    : "{{ grand_text | strip_html | escape }}",
                            "desc"     : "קישור לא מעובד מתפריט {{ top_text | strip_html | escape }} / {{ child_text | strip_html | escape }} / {{ sub_text | strip_html | escape }}: {{ grand_text | strip_html | escape }}",
                            "category" : "{{ top_text | strip_html | escape }}, {{ child_text | strip_html | escape }}, {{ sub_text | strip_html | escape }}, קישור לא מעובד, {{ grand_ext }}",
                            "url"      : "{{ normalized_grand_item | relative_url | escape }}",
                            "date"     : "January 1, 1970"
                          }
                          {% assign first_search_item = false %}
                        {% endunless %}
                      {% endif %}
                    {% endunless %}
                  {% endfor %}
                {% endfor %}
              {% else %}
                {% assign normalized_sub_item = sub_item | strip %}
                {% assign sub_path = normalized_sub_item | split: '#' | first | split: '?' | first | downcase %}
                {% assign sub_ext = sub_path | split: '.' | last %}
                {% assign sub_ext_marker = '|' | append: sub_ext | append: '|' %}
                {% unless normalized_sub_item contains 'javascript:' or normalized_sub_item contains 'mailto:' or normalized_sub_item contains 'tel:' %}
                  {% if normalized_sub_item contains '://' %}
                    {% unless first_search_item %},{% endunless %}
                    {
                      "title"    : "{{ sub_text | strip_html | escape }}",
                      "desc"     : "קישור חיצוני מתפריט {{ top_text | strip_html | escape }} / {{ child_text | strip_html | escape }}: {{ sub_text | strip_html | escape }}",
                      "category" : "{{ top_text | strip_html | escape }}, {{ child_text | strip_html | escape }}, קישור חיצוני",
                      "url"      : "{{ normalized_sub_item | escape }}",
                      "date"     : "January 1, 1970"
                    }
                    {% assign first_search_item = false %}
                  {% elsif sub_path contains '.' %}
                    {% unless menu_markdown_exts contains sub_ext_marker %}
                      {% unless first_search_item %},{% endunless %}
                      {
                        "title"    : "{{ sub_text | strip_html | escape }}",
                        "desc"     : "קישור לא מעובד מתפריט {{ top_text | strip_html | escape }} / {{ child_text | strip_html | escape }}: {{ sub_text | strip_html | escape }}",
                        "category" : "{{ top_text | strip_html | escape }}, {{ child_text | strip_html | escape }}, קישור לא מעובד, {{ sub_ext }}",
                        "url"      : "{{ normalized_sub_item | relative_url | escape }}",
                        "date"     : "January 1, 1970"
                      }
                      {% assign first_search_item = false %}
                    {% endunless %}
                  {% endif %}
                {% endunless %}
              {% endif %}
            {% endfor %}
          {% endfor %}
        {% else %}
          {% assign child_item_path = child_item | strip | split: '#' | first | split: '?' | first | downcase %}
          {% assign child_ext = child_item_path | split: '.' | last %}
          {% assign child_ext_marker = '|' | append: child_ext | append: '|' %}
          {% assign normalized_child_item = child_item | strip %}
          {% unless normalized_child_item contains 'javascript:' or normalized_child_item contains 'mailto:' or normalized_child_item contains 'tel:' %}
            {% if normalized_child_item contains '://' %}
              {% unless first_search_item %},{% endunless %}
              {
                "title"    : "{{ child_text | strip_html | escape }}",
                "desc"     : "קישור חיצוני מתפריט {{ top_text | strip_html | escape }}: {{ child_text | strip_html | escape }}",
                "category" : "{{ top_text | strip_html | escape }}, קישור חיצוני",
                "url"      : "{{ normalized_child_item | escape }}",
                "date"     : "January 1, 1970"
              }
              {% assign first_search_item = false %}
            {% elsif child_item_path contains '.' %}
              {% unless menu_markdown_exts contains child_ext_marker %}
                {% unless first_search_item %},{% endunless %}
                {
                  "title"    : "{{ child_text | strip_html | escape }}",
                  "desc"     : "קישור לא מעובד מתפריט {{ top_text | strip_html | escape }}: {{ child_text | strip_html | escape }}",
                  "category" : "{{ top_text | strip_html | escape }}, קישור לא מעובד, {{ child_ext }}",
                  "url"      : "{{ normalized_child_item | relative_url | escape }}",
                  "date"     : "January 1, 1970"
                }
                {% assign first_search_item = false %}
              {% endunless %}
            {% endif %}
          {% endunless %}
        {% endif %}
      {% endfor %}
    {% endfor %}
  {% else %}
    {% assign top_item_path = top_item | strip | split: '#' | first | split: '?' | first | downcase %}
    {% assign top_ext = top_item_path | split: '.' | last %}
    {% assign top_ext_marker = '|' | append: top_ext | append: '|' %}
    {% assign normalized_top_item = top_item | strip %}
    {% unless normalized_top_item contains 'javascript:' or normalized_top_item contains 'mailto:' or normalized_top_item contains 'tel:' %}
      {% if normalized_top_item contains '://' %}
        {% unless first_search_item %},{% endunless %}
        {
          "title"    : "{{ top_text | strip_html | escape }}",
          "desc"     : "קישור חיצוני מתפריט: {{ top_text | strip_html | escape }}",
          "category" : "קישור חיצוני",
          "url"      : "{{ normalized_top_item | escape }}",
          "date"     : "January 1, 1970"
        }
        {% assign first_search_item = false %}
      {% elsif top_item_path contains '.' %}
        {% unless menu_markdown_exts contains top_ext_marker %}
          {% unless first_search_item %},{% endunless %}
          {
            "title"    : "{{ top_text | strip_html | escape }}",
            "desc"     : "קישור לא מעובד מתפריט: {{ top_text | strip_html | escape }}",
            "category" : "קישור לא מעובד, {{ top_ext }}",
            "url"      : "{{ normalized_top_item | relative_url | escape }}",
            "date"     : "January 1, 1970"
          }
          {% assign first_search_item = false %}
        {% endunless %}
      {% endif %}
    {% endunless %}
  {% endif %}
{% endfor %}
]
